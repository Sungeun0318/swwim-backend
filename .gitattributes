# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Java sources
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
